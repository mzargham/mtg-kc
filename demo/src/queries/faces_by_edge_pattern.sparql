# models/mtg/queries/faces_by_edge_pattern.sparql
#
# For each face, return the face ID and the sorted multiset of disposition values
# of its three edges. This enables shard/wedge classification without pre-asserted
# structure attributes.
#
# REQ-QUERY-01, REQ-DEMO-05, REQ-VV-05
#
# Returns columns: face, e1, e2, e3, d1, d2, d3
# (edges and dispositions not guaranteed to be sorted — caller should sort/aggregate)
#
# Template parameters: none (operates on full graph)

PREFIX kc:   <https://example.org/kc#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX mtg:  <https://example.org/mtg#>

SELECT ?face ?e1 ?e2 ?e3 ?d1 ?d2 ?d3
WHERE {
    ?face a/rdfs:subClassOf* kc:Face ;
          kc:boundedBy ?e1 ;
          kc:boundedBy ?e2 ;
          kc:boundedBy ?e3 .
    FILTER (STR(?e1) < STR(?e2) && STR(?e2) < STR(?e3))
    ?e1 mtg:disposition ?d1 .
    ?e2 mtg:disposition ?d2 .
    ?e3 mtg:disposition ?d3 .
}
ORDER BY ?face
