@prefix kc: <https://example.org/kc#> .
@prefix mtg: <https://example.org/mtg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/kc> a owl:Ontology ;
    rdfs:label "Knowledge Complex Core Ontology" ;
    rdfs:comment "Abstract topological backbone: Element, Vertex, Edge, Face, Complex." .

kc:hasElement a owl:ObjectProperty ;
    rdfs:label "hasElement" ;
    rdfs:comment "Membership relation: an element belongs to this complex." ;
    rdfs:domain kc:Complex ;
    rdfs:range kc:Element .

mtg:_complex a kc:Complex ;
    kc:hasElement mtg:BG,
        mtg:BR,
        mtg:BRG,
        mtg:Black,
        mtg:Blue,
        mtg:GW,
        mtg:Green,
        mtg:RG,
        mtg:Red,
        mtg:UB,
        mtg:UBG,
        mtg:UBR,
        mtg:UG,
        mtg:UR,
        mtg:URG,
        mtg:WB,
        mtg:WBG,
        mtg:WBR,
        mtg:WR,
        mtg:WRG,
        mtg:WU,
        mtg:WUB,
        mtg:WUG,
        mtg:WUR,
        mtg:White .

mtg:at_best a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:at_worst a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:clan a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: esper, grixis, jund, naya, bant, mardu, temur, abzan, jeskai, sultai" ;
    rdfs:domain mtg:ColorTriple ;
    rdfs:range xsd:string .

mtg:disposition a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: adjacent, opposite" ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

mtg:example_behaviors a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:example_decks a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:goal a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: peace, perfection, satisfaction, freedom, harmony" ;
    rdfs:domain mtg:Color ;
    rdfs:range xsd:string .

mtg:guild a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: azorius, dimir, rakdos, gruul, selesnya, orzhov, boros, simic, izzet, golgari" ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

mtg:method a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: order, knowledge, ruthlessness, action, acceptance" ;
    rdfs:domain mtg:Color ;
    rdfs:range xsd:string .

mtg:persona a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:playstyle a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:structure a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: shard, wedge" ;
    rdfs:domain mtg:ColorTriple ;
    rdfs:range xsd:string .

mtg:theme a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: design, growth_mindset, independence, authenticity, community, tribalism, heroism, truth_seeking, creativity, profanity" ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

kc:Face a owl:Class ;
    rdfs:label "Face" ;
    rdfs:comment "Abstract 2-simplex. Boundary: exactly 3 edges. Concrete types must subclass this." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass kc:Edge ;
            owl:onProperty kc:boundedBy ;
            owl:qualifiedCardinality "3"^^xsd:nonNegativeInteger ],
        kc:Element .

mtg:BRG a mtg:ColorTriple ;
    kc:boundedBy mtg:BG,
        mtg:BR,
        mtg:RG ;
    mtg:at_best "Radical honesty, raw vitality, living fully without pretense." ;
    mtg:at_worst "Savage nihilism, predatory self-interest, contempt for civilization." ;
    mtg:clan "jund" ;
    mtg:example_behaviors "Embracing primal vitality without apology",
        "Living with raw honesty and no pretense",
        "Refusing to follow rules that don't serve reality" ;
    mtg:persona "A feral realism with no sugar coating. Self-aware self-indulgence that doesn't pretend to be anything it isn't. Refusal to follow contrived rules." .

mtg:UBG a mtg:ColorTriple ;
    kc:boundedBy mtg:BG,
        mtg:UB,
        mtg:UG ;
    mtg:at_best "Deep strategic patience, knowledge that respects natural limits, pragmatic transgression in service of understanding." ;
    mtg:at_worst "Calculating exploitation of natural systems, amoral pursuit of power through forbidden knowledge." ;
    mtg:clan "sultai" ;
    mtg:example_behaviors "Combining strategic patience with unyielding ambition",
        "Pursuing forbidden knowledge with patient determination",
        "Respecting natural power while bending social rules" ;
    mtg:persona "A driven wanting — not fiery or passionate but sure and unyielding. Willing to break any rule or law, but respectful of the power of nature and fate." .

mtg:UBR a mtg:ColorTriple ;
    kc:boundedBy mtg:BR,
        mtg:UB,
        mtg:UR ;
    mtg:at_best "Revolutionary creativity, passionate excellence, transformative vision." ;
    mtg:at_worst "Megalomaniacal destruction, brilliant cruelty, narcissistic reinvention." ;
    mtg:clan "grixis" ;
    mtg:example_behaviors "Breaking the status quo to rebuild something better",
        "Combining brilliance with bold self-expression",
        "Pursuing personal vision with passionate intensity" ;
    mtg:persona "A bold and impassioned search for satisfaction, perfection, and self-expression. Eagerness to break the status quo and remake things in your own image." .

mtg:URG a mtg:ColorTriple ;
    kc:boundedBy mtg:RG,
        mtg:UG,
        mtg:UR ;
    mtg:at_best "Pure wonder, ego-less exploration, creative play that generates genuine insight." ;
    mtg:at_worst "Aimless wandering, refusal to commit, childish avoidance of responsibility." ;
    mtg:clan "temur" ;
    mtg:example_behaviors "Exploring with childlike curiosity and no ego",
        "Playing creatively as a path to genuine discovery",
        "Pursuing understanding without self-consciousness" ;
    mtg:persona "A childlike curiosity and Zen-like knowledge of self. Insatiable desire to play, explore, discover, and understand, without self-consciousness or ego." .

mtg:WBG a mtg:ColorTriple ;
    kc:boundedBy mtg:BG,
        mtg:GW,
        mtg:WB ;
    mtg:at_best "Enduring traditions that sustain communities, practical wisdom passed through generations." ;
    mtg:at_worst "Fundamentalist rigidity, brutal enforcement of ancient codes, hostility to curiosity." ;
    mtg:clan "abzan" ;
    mtg:example_behaviors "Maintaining traditions that have proven their worth",
        "Passing practical wisdom through generations",
        "Protecting a way of life with unyielding determination" ;
    mtg:persona "Unyielding certainty about one's place in the world. Adherence to ancient law, savage will to survive and protect a way of life. Stolid practicality." .

mtg:WBR a mtg:ColorTriple ;
    kc:boundedBy mtg:BR,
        mtg:WB,
        mtg:WR ;
    mtg:at_best "Decisive heroism, fierce protection of the vulnerable, principled action without overthinking." ;
    mtg:at_worst "Mercenary volatility, violent tribalism, honor codes that justify cruelty." ;
    mtg:clan "mardu" ;
    mtg:example_behaviors "Choosing a cause and defending it with total commitment",
        "Moving on once the immediate fight is won",
        "Taking decisive action without need for deep justification" ;
    mtg:persona "The folk hero archetype — chooses a people or principle to defend, stands ground, then moves on. No need for deeper truth or wisdom." .

mtg:WRG a mtg:ColorTriple ;
    kc:boundedBy mtg:GW,
        mtg:RG,
        mtg:WR ;
    mtg:at_best "Warm-hearted community, joyful tradition, courageous protection of the good." ;
    mtg:at_worst "Parochial tribalism, anti-intellectual hostility to change, sentimental blindness." ;
    mtg:clan "naya" ;
    mtg:example_behaviors "Celebrating and protecting cherished traditions",
        "Committing fully to one's community and way of life",
        "Defending what's good with passionate conviction" ;
    mtg:persona "A passionate presence tempered by tradition and belongingness. Full and vibrant commitment to one's chosen way of life, with fierce desire to protect what already is." .

mtg:WUB a mtg:ColorTriple ;
    kc:boundedBy mtg:UB,
        mtg:WB,
        mtg:WU ;
    mtg:at_best "Masterful strategic planning, building institutions that actually work, principled pragmatism." ;
    mtg:at_worst "Cold technocracy, dismissal of human feeling, elitist tribalism." ;
    mtg:clan "esper" ;
    mtg:example_behaviors "Applying cold logic to complex social problems",
        "Building efficient systems that serve a select group",
        "Strategic long-term planning without sentimentality" ;
    mtg:persona "A coolly calculated, methodical approach toward building a better future for oneself and one's circle. Absent frivolous emotion or excessive concern for harmony." .

mtg:WUG a mtg:ColorTriple ;
    kc:boundedBy mtg:GW,
        mtg:UG,
        mtg:WU ;
    mtg:at_best "Serene wisdom, institutions that nurture growth, patient pursuit of understanding." ;
    mtg:at_worst "Complacent stagnation, gentle tyranny of low expectations, passionless order." ;
    mtg:clan "bant" ;
    mtg:example_behaviors "Building patient, nurturing institutional structures",
        "Creating scaffolds that support growth without constraining it",
        "Pursuing wisdom through calm and steady progression" ;
    mtg:persona "A calm and peaceful stability underlying slow progression toward knowledge, wisdom, and fulfillment. Scaffolds rather than cages, patience rather than passion." .

mtg:WUR a mtg:ColorTriple ;
    kc:boundedBy mtg:UR,
        mtg:WR,
        mtg:WU ;
    mtg:at_best "Heroic scholarship, sharing discovery for the common good, principled innovation." ;
    mtg:at_worst "Restless perfectionism, inability to be satisfied, crusading intellectualism." ;
    mtg:clan "jeskai" ;
    mtg:example_behaviors "Cycling between inspired action and careful reflection",
        "Exploring boldly and sharing discoveries with others",
        "Pursuing principled innovation for the common good" ;
    mtg:persona "A cycle of inspiration, investigation, and evaluation. An explorer striding boldly forth and returning with maps to share before departing again." .

kc:Complex a owl:Class ;
    rdfs:label "Complex" ;
    rdfs:comment """A simplicial complex: a collection of elements (simplices) that is
        closed under the boundary operator. If a simplex is in the complex, all its
        boundary elements must also be in the complex. Topological validity of the
        composition is enforced by SHACL (see kcs:ComplexShape).""" .

kc:Edge a owl:Class ;
    rdfs:label "Edge" ;
    rdfs:comment "Abstract 1-simplex. Boundary: exactly 2 vertices. Concrete types must subclass this." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass kc:Vertex ;
            owl:onProperty kc:boundedBy ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        kc:Element .

kc:Vertex a owl:Class ;
    rdfs:label "Vertex" ;
    rdfs:comment "Abstract 0-simplex. Empty boundary (∂v = ∅). Concrete types must subclass this." ;
    rdfs:subClassOf kc:Element .

kc:boundedBy a owl:ObjectProperty ;
    rdfs:label "boundedBy" ;
    rdfs:comment """Boundary operator (∂). Maps a k-simplex to its bounding
        (k-1)-simplices. Cardinality is enforced per subclass via OWL restrictions.
        Vertices (k=0) have empty boundary. For k>=1, cardinality = k+1.
        In this demo all elements are unoriented (boundary is an unordered set).""" ;
    rdfs:domain kc:Element ;
    rdfs:range kc:Element .

mtg:BG a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:Green ;
    mtg:at_best "Unflinching pragmatism, willingness to do what's necessary, ecological wisdom about decay and renewal." ;
    mtg:at_worst "Nihilistic amorality, wallowing in darkness, exploiting natural cycles for selfish ends." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Accepting the necessity of decay for renewal",
        "Embracing the full cycle of growth and decomposition",
        "Getting hands dirty with unpleasant but necessary work" ;
    mtg:guild "golgari" ;
    mtg:persona "Asks 'what costs must be paid to achieve the ideal?' Gets down in the dirt with rot and rebirth. Embraces the cycle of life and death without flinching." ;
    mtg:theme "profanity" .

mtg:BR a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:Red ;
    mtg:at_best "Unapologetic authenticity, liberation from soul-crushing obligation, fierce self-expression." ;
    mtg:at_worst "Destructive hedonism, cruelty dressed up as honesty, chaos without purpose." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Defending personal independence fiercely",
        "Expressing desires without apology",
        "Rejecting obligations that don't serve genuine needs" ;
    mtg:guild "rakdos" ;
    mtg:persona "Asks 'how do I get what I want?' Fosters and defends independence — red from freedom, black from self-reliance. Live and let live." ;
    mtg:theme "independence" .

mtg:GW a mtg:ColorPair ;
    kc:boundedBy mtg:Green,
        mtg:White ;
    mtg:at_best "Compassionate institutions, sustainable cooperation, genuine service." ;
    mtg:at_worst "Groupthink, martyrdom without purpose, smothering collectivism." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Building sustainable communities through shared sacrifice",
        "Creating institutions that serve the common good",
        "Putting collective wellbeing above individual desire" ;
    mtg:guild "selesnya" ;
    mtg:persona "Asks 'what's fair and good? What is sustainable?' The whole can be greater than the sum of its parts. Sacrifice for things larger than oneself." ;
    mtg:theme "community" .

mtg:RG a mtg:ColorPair ;
    kc:boundedBy mtg:Green,
        mtg:Red ;
    mtg:at_best "Visceral aliveness, grounded instinct, acting from genuine feeling rather than performance." ;
    mtg:at_worst "Anti-intellectual rejection of all structure, inability to plan or cooperate." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Acting from gut instinct rather than calculation",
        "Being fully present in the moment",
        "Rejecting artificial narratives about how things should be" ;
    mtg:guild "gruul" ;
    mtg:persona "Asks 'where am I now, and where should I go?' Dionysian presence — setting aside narratives and frames and just being in the moment." ;
    mtg:theme "authenticity" .

mtg:UB a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:Blue ;
    mtg:at_best "Brilliant strategic thinking, self-made excellence, pragmatic intelligence." ;
    mtg:at_worst "Arrogant manipulation, treating people as instruments, cold scheming." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Applying intelligence pragmatically toward goals",
        "Pursuing self-improvement with strategic focus",
        "Refusing to accept inherited limitations" ;
    mtg:guild "dimir" ;
    mtg:persona "Asks 'how can I best achieve my goals?' Enlightened self-interest. You are not defined by your origins or constrained to the role society has set." ;
    mtg:theme "growth_mindset" .

mtg:UG a mtg:ColorPair ;
    kc:boundedBy mtg:Blue,
        mtg:Green ;
    mtg:at_best "Profound insight that bridges knowledge and wisdom, patient investigation of deep truths." ;
    mtg:at_worst "Endless inquiry without action, academic paralysis, detachment from human concerns." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Bridging analytical knowledge with intuitive wisdom",
        "Investigating deep truths with patience and humility",
        "Pursuing understanding for its own sake" ;
    mtg:guild "simic" ;
    mtg:persona "Asks 'what do I not yet understand?' While they disagree on what to do with understanding, both are deeply committed to seeing the world as it is." ;
    mtg:theme "truth_seeking" .

mtg:UR a mtg:ColorPair ;
    kc:boundedBy mtg:Blue,
        mtg:Red ;
    mtg:at_best "Breathtaking invention, inspired creation, boundary-pushing discovery." ;
    mtg:at_worst "Reckless experimentation, brilliance without responsibility, unstable genius." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Combining analytical rigor with creative passion",
        "Creating brilliant but sometimes unstable innovations",
        "Pushing boundaries of what's thought possible" ;
    mtg:guild "izzet" ;
    mtg:persona "Asks 'what can be achieved? What might be possible?' Passion combined with perfection — wild artistry and mad science." ;
    mtg:theme "creativity" .

mtg:WB a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:White ;
    mtg:at_best "Fierce loyalty to one's people, clear moral commitment, protective solidarity." ;
    mtg:at_worst "Us-versus-them bigotry, exploitation of outsiders, corruption within hierarchy." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Drawing sharp lines between in-group and out-group",
        "Enforcing strict codes of conduct within the tribe",
        "Protecting one's own at the expense of outsiders" ;
    mtg:guild "orzhov" ;
    mtg:persona "Asks 'who's in my circle of concern?' Strict codes within the group, near-impunity with outsiders. The good of the group vs. the good of the individual." ;
    mtg:theme "tribalism" .

mtg:WR a mtg:ColorPair ;
    kc:boundedBy mtg:Red,
        mtg:White ;
    mtg:at_best "Courageous action in defense of the vulnerable, moral clarity under pressure." ;
    mtg:at_worst "Zealotry, self-righteous violence, inability to see shades of gray." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Channeling passionate conviction through moral principles",
        "Standing up for the vulnerable when it costs something",
        "Taking decisive action when justice demands it" ;
    mtg:guild "boros" ;
    mtg:persona "Asks 'what needs to be done? What would a good person do?' Passion channeled through morality — warriors, soldiers, vigilantes." ;
    mtg:theme "heroism" .

mtg:WU a mtg:ColorPair ;
    kc:boundedBy mtg:Blue,
        mtg:White ;
    mtg:at_best "Thoughtful systems that genuinely improve outcomes, principled engineering of fairness." ;
    mtg:at_worst "Bureaucratic paralysis, rules that serve themselves rather than their purpose." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Applying rationality techniques to improve outcomes",
        "Building algorithmic heuristics for better decision-making",
        "Designing systems with careful attention to fairness" ;
    mtg:guild "azorius" ;
    mtg:persona "Asks 'how do we know what's right and good?' Carefully defined, algorithmic heuristics for doing things better. Rationality techniques and effective altruism." ;
    mtg:theme "design" .

mtg:Black a mtg:Color ;
    mtg:at_best "Decisive self-reliance, relentless excellence, unflinching honesty about incentives." ;
    mtg:at_worst "Short-sighted transactionalism that drives away allies, consuming everything without sustainability." ;
    mtg:example_behaviors "Being honest about self-interest and incentives",
        "Making hard choices others shy away from",
        "Pursuing personal goals with relentless determination" ;
    mtg:goal "satisfaction" ;
    mtg:method "ruthlessness" ;
    mtg:persona "Wants power and agency to act on its preferences, reshaping the world as it sees fit. Amoral rather than immoral — recognizes no limits except self-interest." .

mtg:Blue a mtg:Color ;
    mtg:at_best "Visionary insight, elegant invention, patient mastery of complex systems." ;
    mtg:at_worst "Dismissive of what it cannot quantify, paralyzed by analysis, emotionally disconnected." ;
    mtg:example_behaviors "Designing elegant solutions to complex problems",
        "Optimizing systems through careful analysis",
        "Pursuing deep understanding before acting" ;
    mtg:goal "perfection" ;
    mtg:method "knowledge" ;
    mtg:persona "Believes things could be arbitrarily good if we could figure out the truth and apply it fully. Values clarity, rigor, and optimization." .

mtg:Green a mtg:Color ;
    mtg:at_best "Grounded wisdom, patient strength, deep respect for interconnection and balance." ;
    mtg:at_worst "Pathological passivity that surrenders to fate and sabotages others' attempts to improve things." ;
    mtg:example_behaviors "Accepting circumstances and working within natural limits",
        "Finding strength in patience and rootedness",
        "Respecting tradition and the wisdom of experience" ;
    mtg:goal "harmony" ;
    mtg:method "acceptance" ;
    mtg:persona "Believes most suffering comes from trying to cast off one's natural role. Seeks harmony as distinct from order — embracing what is." .

mtg:Red a mtg:Color ;
    mtg:at_best "Fierce loyalty, joyful creation, courage to act when others hesitate." ;
    mtg:at_worst "Restless impulsivity that cannot commit or tolerate stillness, flailing emotional volatility." ;
    mtg:example_behaviors "Acting on passionate conviction without hesitation",
        "Expressing emotions openly and authentically",
        "Taking bold risks in pursuit of what matters" ;
    mtg:goal "freedom" ;
    mtg:method "action" ;
    mtg:persona "Wants to live in the moment and follow the thread of aliveness and passion. Values authenticity, courage, and emotional truth." .

mtg:White a mtg:Color ;
    mtg:at_best "Compassionate leadership, principled sacrifice, building systems that protect the vulnerable." ;
    mtg:at_worst "Rigid authoritarianism that cannot tolerate ambiguity, empty ritual, suffocating conformity." ;
    mtg:example_behaviors "Building institutions that protect the vulnerable",
        "Creating fair rules and enforcing them consistently",
        "Sacrificing personal gain for the greater good" ;
    mtg:goal "peace" ;
    mtg:method "order" ;
    mtg:persona "Believes the solution to suffering is coordination, cooperation, and rules. Values fairness, duty, and the greater good." .

kc:Element a owl:Class ;
    rdfs:label "Element" ;
    rdfs:comment """Abstract topological element (k-simplex). All KC types are elements.
        The simplex order k determines boundary cardinality:
          k=0 (Vertex): empty boundary (cardinality 0)
          k=1 (Edge):   2 boundary vertices
          k=2 (Face):   3 boundary edges
          k>=1 general: (k+1) boundary (k-1)-simplices
        Higher orders can be defined by subclassing Element.""" .

mtg:Color a owl:Class ;
    rdfs:subClassOf kc:Vertex .

mtg:ColorTriple a owl:Class ;
    rdfs:subClassOf kc:Face .

mtg:ColorPair a owl:Class ;
    rdfs:subClassOf kc:Edge .

