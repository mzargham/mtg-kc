@prefix kc: <https://example.org/kc#> .
@prefix mtg: <https://example.org/mtg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/kc> a owl:Ontology ;
    rdfs:label "Knowledge Complex Core Ontology" ;
    rdfs:comment "Abstract topological backbone: Element, Vertex, Edge, Face, Complex." .

kc:hasElement a owl:ObjectProperty ;
    rdfs:label "hasElement" ;
    rdfs:comment "Membership relation: an element belongs to this complex." ;
    rdfs:domain kc:Complex ;
    rdfs:range kc:Element .

mtg:_complex a kc:Complex ;
    kc:hasElement mtg:BG,
        mtg:BR,
        mtg:BRG,
        mtg:Black,
        mtg:Blue,
        mtg:GW,
        mtg:Green,
        mtg:RG,
        mtg:Red,
        mtg:UB,
        mtg:UBG,
        mtg:UBR,
        mtg:UG,
        mtg:UR,
        mtg:URG,
        mtg:WB,
        mtg:WBG,
        mtg:WBR,
        mtg:WR,
        mtg:WRG,
        mtg:WU,
        mtg:WUB,
        mtg:WUG,
        mtg:WUR,
        mtg:White .

mtg:at_best a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:at_worst a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:clan a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: esper, grixis, jund, naya, bant, mardu, temur, abzan, jeskai, sultai" ;
    rdfs:domain mtg:ColorTriple ;
    rdfs:range xsd:string .

mtg:closure a owl:DatatypeProperty ;
    rdfs:domain mtg:ColorTriple ;
    rdfs:range xsd:string .

mtg:disposition a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: adjacent, opposite" ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

mtg:example_behaviors a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:example_decks a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:goal a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: peace, perfection, satisfaction, freedom, harmony" ;
    rdfs:domain mtg:Color ;
    rdfs:range xsd:string .

mtg:guild a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: azorius, dimir, rakdos, gruul, selesnya, orzhov, boros, simic, izzet, golgari" ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

mtg:method a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: order, knowledge, ruthlessness, action, acceptance" ;
    rdfs:domain mtg:Color ;
    rdfs:range xsd:string .

mtg:persona a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:playstyle a owl:DatatypeProperty ;
    rdfs:range xsd:string .

mtg:structure a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: shard, wedge" ;
    rdfs:domain mtg:ColorTriple ;
    rdfs:range xsd:string .

mtg:synergies a owl:DatatypeProperty ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

mtg:tensions a owl:DatatypeProperty ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

mtg:thematic_triad a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: design, growth_mindset, independence, authenticity, community, tribalism, heroism, truth_seeking, creativity, profanity" ;
    rdfs:domain mtg:ColorTriple ;
    rdfs:range xsd:string .

mtg:theme a owl:DatatypeProperty ;
    rdfs:comment "Allowed values: design, growth_mindset, independence, authenticity, community, tribalism, heroism, truth_seeking, creativity, profanity" ;
    rdfs:domain mtg:ColorPair ;
    rdfs:range xsd:string .

kc:Face a owl:Class ;
    rdfs:label "Face" ;
    rdfs:comment "Abstract 2-simplex. Boundary: exactly 3 edges. Concrete types must subclass this." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass kc:Edge ;
            owl:onProperty kc:boundedBy ;
            owl:qualifiedCardinality "3"^^xsd:nonNegativeInteger ],
        kc:Element .

mtg:BRG a mtg:ColorTriple ;
    kc:boundedBy mtg:BG,
        mtg:BR,
        mtg:RG ;
    mtg:at_best "Radical honesty, raw vitality, living fully without pretense." ;
    mtg:at_worst "Savage nihilism, predatory self-interest, contempt for civilization." ;
    mtg:clan "jund" ;
    mtg:closure "Independence, present-moment authenticity, and ecological brutality close into the starkest realism: the world is what it is, power determines outcomes, and pretense is the only real crime. Jund's closure is that when you strip every comforting narrative, what remains is raw vitality — unglamorous and honest, its own form of wholeness." ;
    mtg:example_behaviors "Embracing primal vitality without apology",
        "Living with raw honesty and no pretense",
        "Refusing to follow rules that don't serve reality" ;
    mtg:persona "A feral realism with no sugar coating. Self-aware self-indulgence that doesn't pretend to be anything it isn't. Refusal to follow contrived rules." ;
    mtg:thematic_triad "authenticity",
        "independence",
        "profanity" .

mtg:UBG a mtg:ColorTriple ;
    kc:boundedBy mtg:BG,
        mtg:UB,
        mtg:UG ;
    mtg:at_best "Deep strategic patience, knowledge that respects natural limits, pragmatic transgression in service of understanding." ;
    mtg:at_worst "Calculating exploitation of natural systems, amoral pursuit of power through forbidden knowledge." ;
    mtg:clan "sultai" ;
    mtg:closure "Growth-seeking, ecological ruthlessness, and patient truth-seeking converge into the most calculating of orientations: a hunger that respects nothing except what actually works. Sultai's closure is that when you understand natural systems deeply enough to transgress their rules without destroying them, you gain access to power that those who respect the rules cannot touch." ;
    mtg:example_behaviors "Combining strategic patience with unyielding ambition",
        "Pursuing forbidden knowledge with patient determination",
        "Respecting natural power while bending social rules" ;
    mtg:persona "A driven wanting — not fiery or passionate but sure and unyielding. Willing to break any rule or law, but respectful of the power of nature and fate." ;
    mtg:thematic_triad "growth_mindset",
        "profanity",
        "truth_seeking" .

mtg:UBR a mtg:ColorTriple ;
    kc:boundedBy mtg:BR,
        mtg:UB,
        mtg:UR ;
    mtg:at_best "Revolutionary creativity, passionate excellence, transformative vision unconstrained by precedent." ;
    mtg:at_worst "Megalomaniacal destruction, brilliant cruelty, narcissistic reinvention that burns everything it cannot use." ;
    mtg:clan "grixis" ;
    mtg:closure "Strategic self-reinvention, fierce independence, and creative passion close into a force that refuses all inherited constraints on what is possible. The synergies between the pairs amplify each other: dimir's precision feeds izzet's invention, rakdos's defiance removes the last inhibitions. Grixis doesn't just break the status quo — it remakes reality in its own image." ;
    mtg:example_behaviors "Breaking the status quo to rebuild something better",
        "Combining brilliance with bold self-expression",
        "Pursuing personal vision with passionate intensity" ;
    mtg:persona "A bold and impassioned search for satisfaction, perfection, and self-expression. Eagerness to break the status quo and remake things in your own image." ;
    mtg:thematic_triad "creativity",
        "growth_mindset",
        "independence" .

mtg:URG a mtg:ColorTriple ;
    kc:boundedBy mtg:RG,
        mtg:UG,
        mtg:UR ;
    mtg:at_best "Embodied wisdom that can't be taught from books, fearless encounter with the unknown, creative insight born from genuine experience rather than inference." ;
    mtg:at_worst "Dismissal of accumulated knowledge as inauthentic, restless movement that prevents depth, mistaking novelty of experience for genuine understanding." ;
    mtg:clan "temur" ;
    mtg:closure "Creative passion, present-moment authenticity, and patient truth-seeking converge into embodied knowing — understanding accumulated through encounter rather than analysis. Unlike simic's careful inquiry or izzet's systematic invention, temur's knowing is shamanic: you understand the storm by being in it. The closure is that direct experience, unmediated by framework, generates insight that study alone cannot reach." ;
    mtg:example_behaviors "Engaging with what is wild and uncontrolled rather than taming it for systematic study",
        "Seeking direct experience rather than second-hand information",
        "Trusting embodied knowledge earned through encounter over conclusions reached at a distance" ;
    mtg:persona "Knowledge earned through encounter — not study or analysis but direct immersion in what is wild and uncontrolled. Temur accumulates understanding by living fully in the world as it actually is, without the mediation of frameworks or categories." ;
    mtg:thematic_triad "authenticity",
        "creativity",
        "truth_seeking" .

mtg:WBG a mtg:ColorTriple ;
    kc:boundedBy mtg:BG,
        mtg:GW,
        mtg:WB ;
    mtg:at_best "Resilience that carries communities through catastrophe, solidarity forged under pressure, inherited discipline that actually works when things get hard." ;
    mtg:at_worst "Crushing conformity that mistakes survival for flourishing, hostility to anything untested by suffering, sacrificing individuals to preserve the form of the group." ;
    mtg:clan "abzan" ;
    mtg:closure "When tribal codes, ecological ruthlessness, and communal endurance operate together, the result is a group that survives by treating hardship as instruction. The synergy between golgari's cycle-wisdom and selesnya's communal bonds is hardened by orzhov's in-group discipline: Abzan outlasts because it absorbs loss rather than denying it." ;
    mtg:example_behaviors "Choosing proven methods over promising but unproven alternatives",
        "Drawing strength from continuity with those who endured before",
        "Honoring obligations even when they are personally costly" ;
    mtg:persona "Endurance as a form of wisdom. The clan survives not by winning every battle but by outlasting every adversary. Ancient law exists because it has been tested by suffering — what remains standing has earned its authority." ;
    mtg:thematic_triad "community",
        "profanity",
        "tribalism" .

mtg:WBR a mtg:ColorTriple ;
    kc:boundedBy mtg:BR,
        mtg:WB,
        mtg:WR ;
    mtg:at_best "Decisive heroism, fierce clarity about what must be done, the courage to act and then let go." ;
    mtg:at_worst "Mercenary volatility, violent tribalism, honor codes that justify cruelty to outsiders." ;
    mtg:clan "mardu" ;
    mtg:closure "Tribal loyalty, fierce independence, and heroic action fuse into the warrior's code: total commitment to your band in the moment of the fight, and total freedom from obligation once the fight is done. The closure is the deed — not sustained institution, not philosophical framework, but the act itself as its own justification. Mardu moves on." ;
    mtg:example_behaviors "Acting without needing philosophical justification — the deed speaks for itself",
        "Committing fully to the fight in front of you, not the fight you wish you were having",
        "Moving on once the immediate obligation is fulfilled" ;
    mtg:persona "The folk hero archetype — chooses a people or principle to defend, stands ground, then moves on. No need for deeper truth or wisdom." ;
    mtg:thematic_triad "heroism",
        "independence",
        "tribalism" .

mtg:WRG a mtg:ColorTriple ;
    kc:boundedBy mtg:GW,
        mtg:RG,
        mtg:WR ;
    mtg:at_best "Infectious generosity, warm-hearted defense of what's genuinely good, the courage to celebrate openly even when the world is difficult." ;
    mtg:at_worst "Naïve blindness to real threats, sentimental attachment to a way of life that can't survive contact with the world, paradise thinking that turns parochial." ;
    mtg:clan "naya" ;
    mtg:closure "Heroic action, present-moment authenticity, and communal belonging close into a single experience: celebration. When you defend from abundance rather than scarcity, when you act from passion within a community that already accepts you, the defense itself becomes joyful. Naya's closure is protection as expression — not obligation." ;
    mtg:example_behaviors "Defending a way of life from a place of abundance rather than scarcity",
        "Expressing gratitude for what already exists rather than striving for what's missing",
        "Hosting and celebrating rather than hoarding and defending" ;
    mtg:persona "The world as it should be — abundant, alive, and worth celebrating. Naya doesn't survive adversity so much as it radiates against it. Joy, belonging, and passion without needing to justify them." ;
    mtg:thematic_triad "authenticity",
        "community",
        "heroism" .

mtg:WUB a mtg:ColorTriple ;
    kc:boundedBy mtg:UB,
        mtg:WB,
        mtg:WU ;
    mtg:at_best "Masterful strategic planning, precision execution, principled pragmatism in service of those who earned their seat." ;
    mtg:at_worst "Cold technocracy, architecture of exclusion dressed as meritocracy, contempt for those outside the design." ;
    mtg:clan "esper" ;
    mtg:closure "When the design impulse, the growth mindset, and the tribal circle of concern assemble, the result is a system built for the advancement of a defined group — merit within, exclusivity without. The synergies between the pairs produce something colder than any pair alone: a technocracy that is rigorous, self-serving, and self-justifying." ;
    mtg:example_behaviors "Executing long-term strategies with cold precision and without self-doubt",
        "Identifying who has the competence to make consequential decisions",
        "Redesigning systems to eliminate inefficiency and sentimentality" ;
    mtg:persona "A coolly calculated, methodical approach toward building a better future for oneself and one's circle. Absent frivolous emotion or excessive concern for harmony." ;
    mtg:thematic_triad "design",
        "growth_mindset",
        "tribalism" .

mtg:WUG a mtg:ColorTriple ;
    kc:boundedBy mtg:GW,
        mtg:UG,
        mtg:WU ;
    mtg:at_best "Institutions that develop genuine human excellence, principled patience that enables real mastery, chivalric virtue that is both idealistic and effective." ;
    mtg:at_worst "Complacent meritocracy that mistakes credential for virtue, gentle paternalism that stifles those it purports to develop, stability that becomes inertia." ;
    mtg:clan "bant" ;
    mtg:closure "Careful design, patient truth-seeking, and communal harmony converge into something uncommon: an institution that genuinely develops people rather than merely constraining or using them. The absence of Black means no tension toward exploitation — Bant's closure is civilization that has learned to cultivate." ;
    mtg:example_behaviors "Building institutions that genuinely help people grow into their potential",
        "Mentoring and developing talent through structured, patient practice",
        "Upholding principles even when it is costly or inconvenient to do so" ;
    mtg:persona "Civilization as a form of moral cultivation. Society exists not merely to function but to develop — Bant builds the structures that allow people to become their best selves, through patience, honor, and respect for what has already been grown." ;
    mtg:thematic_triad "community",
        "design",
        "truth_seeking" .

mtg:WUR a mtg:ColorTriple ;
    kc:boundedBy mtg:UR,
        mtg:WR,
        mtg:WU ;
    mtg:at_best "Heroic scholarship, principled innovation, the courage to explore and the discipline to bring back something useful." ;
    mtg:at_worst "Restless perfectionism that can never be satisfied, crusading intellectualism that imposes its findings on others." ;
    mtg:clan "jeskai" ;
    mtg:closure "Design, creativity, and heroism assembled together produce the scholar-warrior: a person who studies in order to act, acts in order to discover, and returns to share what was learned. The cycle of training, mastery, and teaching is self-reinforcing — each iteration raises the ceiling of what is possible." ;
    mtg:example_behaviors "Cycling between inspired action and careful reflection",
        "Exploring boldly and sharing discoveries with others",
        "Pursuing principled innovation for the common good" ;
    mtg:persona "A cycle of inspiration, investigation, and evaluation. An explorer striding boldly forth and returning with maps to share before departing again." ;
    mtg:thematic_triad "creativity",
        "design",
        "heroism" .

kc:Complex a owl:Class ;
    rdfs:label "Complex" ;
    rdfs:comment """A simplicial complex: a collection of elements (simplices) that is
        closed under the boundary operator. If a simplex is in the complex, all its
        boundary elements must also be in the complex. Topological validity of the
        composition is enforced by SHACL (see kcs:ComplexShape).""" .

kc:Edge a owl:Class ;
    rdfs:label "Edge" ;
    rdfs:comment "Abstract 1-simplex. Boundary: exactly 2 vertices. Concrete types must subclass this." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass kc:Vertex ;
            owl:onProperty kc:boundedBy ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        kc:Element .

kc:Vertex a owl:Class ;
    rdfs:label "Vertex" ;
    rdfs:comment "Abstract 0-simplex. Empty boundary (∂v = ∅). Concrete types must subclass this." ;
    rdfs:subClassOf kc:Element .

kc:boundedBy a owl:ObjectProperty ;
    rdfs:label "boundedBy" ;
    rdfs:comment """Boundary operator (∂). Maps a k-simplex to its bounding
        (k-1)-simplices. Cardinality is enforced per subclass via OWL restrictions.
        Vertices (k=0) have empty boundary. For k>=1, cardinality = k+1.
        In this demo all elements are unoriented (boundary is an unordered set).""" ;
    rdfs:domain kc:Element ;
    rdfs:range kc:Element .

mtg:BG a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:Green ;
    mtg:at_best "Unflinching pragmatism, willingness to do what's necessary, ecological wisdom about decay and renewal." ;
    mtg:at_worst "Nihilistic amorality, wallowing in darkness, exploiting natural cycles for selfish ends." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Accepting the necessity of decay for renewal",
        "Embracing the full cycle of growth and decomposition",
        "Getting hands dirty with unpleasant but necessary work" ;
    mtg:guild "golgari" ;
    mtg:persona "Asks 'what costs must be paid to achieve the ideal?' Gets down in the dirt with rot and rebirth. Embraces the cycle of life and death without flinching." ;
    mtg:synergies "Green's acceptance of natural cycles — growth, decay, renewal — gives Black's ruthlessness an ecological framework: consuming is not merely selfish, it is part of the cycle. Black's willingness to face death directly enables Green's wisdom about decay." ;
    mtg:tensions "Black exploits cycles for individual gain; Green participates in them for collective balance. Black's self-interest can strip-mine natural systems that Green regards as sacred. Green's patience conflicts with Black's drive for immediate results." ;
    mtg:theme "profanity" .

mtg:BR a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:Red ;
    mtg:at_best "Unapologetic authenticity, liberation from soul-crushing obligation, fierce self-expression." ;
    mtg:at_worst "Destructive hedonism, cruelty dressed up as honesty, chaos without purpose." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Defending personal independence fiercely",
        "Expressing desires without apology",
        "Rejecting obligations that don't serve genuine needs" ;
    mtg:guild "rakdos" ;
    mtg:persona "Asks 'how do I get what I want?' Fosters and defends independence — red from freedom, black from self-reliance. Live and let live." ;
    mtg:synergies "Black's self-reliance and Red's freedom point toward the same target: autonomy from external obligation. Black provides the strategic clarity; Red provides the passionate will to act on it immediately." ;
    mtg:tensions "Black plans; Red acts. Black's long-term self-interest can be derailed by Red's impulsive pursuit of immediate satisfaction. Red's emotional authenticity conflicts with Black's cold instrumental reasoning." ;
    mtg:theme "independence" .

mtg:GW a mtg:ColorPair ;
    kc:boundedBy mtg:Green,
        mtg:White ;
    mtg:at_best "Compassionate institutions, sustainable cooperation, genuine service." ;
    mtg:at_worst "Groupthink, martyrdom without purpose, smothering collectivism." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Building sustainable communities through shared sacrifice",
        "Creating institutions that serve the common good",
        "Putting collective wellbeing above individual desire" ;
    mtg:guild "selesnya" ;
    mtg:persona "Asks 'what's fair and good? What is sustainable?' The whole can be greater than the sum of its parts. Sacrifice for things larger than oneself." ;
    mtg:synergies "Green's embrace of natural interdependence and White's commitment to collective order reinforce each other — both believe the individual is fulfilled through proper relationship with the whole." ;
    mtg:tensions "White's order is designed and enforced; Green's harmony is grown and accepted. White wants to build better systems; Green believes the best system is already present in nature. White can override what is for what ought to be; Green cannot." ;
    mtg:theme "community" .

mtg:RG a mtg:ColorPair ;
    kc:boundedBy mtg:Green,
        mtg:Red ;
    mtg:at_best "Visceral aliveness, grounded instinct, acting from genuine feeling rather than performance." ;
    mtg:at_worst "Anti-intellectual rejection of all structure, inability to plan or cooperate." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Acting from gut instinct rather than calculation",
        "Being fully present in the moment",
        "Rejecting artificial narratives about how things should be" ;
    mtg:guild "gruul" ;
    mtg:persona "Asks 'where am I now, and where should I go?' Dionysian presence — setting aside narratives and frames and just being in the moment." ;
    mtg:synergies "Red's freedom from narrative and Green's acceptance of what is converge on the same present-moment orientation. Neither is interested in abstract ideals — both trust immediate experience over constructed frameworks." ;
    mtg:tensions "Red generates momentum and change; Green resists disrupting what has proven itself. Red's passion can be destructive; Green's acceptance can be passive. Red wants to break constraints; Green wants to work within natural ones." ;
    mtg:theme "authenticity" .

mtg:UB a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:Blue ;
    mtg:at_best "Brilliant strategic thinking, self-made excellence, pragmatic intelligence." ;
    mtg:at_worst "Arrogant manipulation, treating people as instruments, cold scheming." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Applying intelligence pragmatically toward goals",
        "Pursuing self-improvement with strategic focus",
        "Refusing to accept inherited limitations" ;
    mtg:guild "dimir" ;
    mtg:persona "Asks 'how can I best achieve my goals?' Enlightened self-interest. You are not defined by your origins or constrained to the role society has set." ;
    mtg:synergies "Blue's mastery of knowledge gives Black's ambition a precision instrument. Black's willingness to discard sentiment clears the path for Blue's analytical conclusions to be applied without compromise." ;
    mtg:tensions "Blue treats knowledge as an end in itself; Black treats it as a means to satisfaction. Black's impatience with prolonged analysis conflicts with Blue's need for thoroughness; Blue's search for objective truth conflicts with Black's fundamentally self-referential goal." ;
    mtg:theme "growth_mindset" .

mtg:UG a mtg:ColorPair ;
    kc:boundedBy mtg:Blue,
        mtg:Green ;
    mtg:at_best "Profound insight that bridges knowledge and wisdom, patient investigation of deep truths." ;
    mtg:at_worst "Endless inquiry without action, academic paralysis, detachment from human concerns." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Bridging analytical knowledge with intuitive wisdom",
        "Investigating deep truths with patience and humility",
        "Pursuing understanding for its own sake" ;
    mtg:guild "simic" ;
    mtg:persona "Asks 'what do I not yet understand?' While they disagree on what to do with understanding, both are deeply committed to seeing the world as it is." ;
    mtg:synergies "Both are committed to seeing the world as it actually is — Blue through analysis, Green through acceptance. Blue's rigor and Green's reverence together resist the temptation to force findings into predetermined categories." ;
    mtg:tensions "Blue wants to understand nature in order to improve it; Green wants to understand it in order to harmonize with it. Blue's drive toward optimization conflicts with Green's conviction that what is natural is already sufficient. Blue abstracts; Green embeds." ;
    mtg:theme "truth_seeking" .

mtg:UR a mtg:ColorPair ;
    kc:boundedBy mtg:Blue,
        mtg:Red ;
    mtg:at_best "Breathtaking invention, inspired creation, boundary-pushing discovery." ;
    mtg:at_worst "Reckless experimentation, brilliance without responsibility, unstable genius." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Combining analytical rigor with creative passion",
        "Creating brilliant but sometimes unstable innovations",
        "Pushing boundaries of what's thought possible" ;
    mtg:guild "izzet" ;
    mtg:persona "Asks 'what can be achieved? What might be possible?' Passion combined with perfection — wild artistry and mad science." ;
    mtg:synergies "Blue's drive toward perfection and Red's passionate action fuse into relentless creation. Blue provides the analytical framework; Red provides the energy to push past caution and convention." ;
    mtg:tensions "Blue wants to understand fully before acting; Red acts first and adjusts. Blue's perfectionism frustrates Red's impatience; Red's volatility frustrates Blue's need for precision. Blue is systematic; Red is improvisational." ;
    mtg:theme "creativity" .

mtg:WB a mtg:ColorPair ;
    kc:boundedBy mtg:Black,
        mtg:White ;
    mtg:at_best "Fierce loyalty to one's people, clear moral commitment, protective solidarity." ;
    mtg:at_worst "Us-versus-them bigotry, exploitation of outsiders, corruption within hierarchy." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Drawing sharp lines between in-group and out-group",
        "Enforcing strict codes of conduct within the tribe",
        "Protecting one's own at the expense of outsiders" ;
    mtg:guild "orzhov" ;
    mtg:persona "Asks 'who's in my circle of concern?' Strict codes within the group, near-impunity with outsiders. The good of the group vs. the good of the individual." ;
    mtg:synergies "White's strict codes give Black's self-interest a legible, enforceable structure — the in-group benefits from real coordination. Black's ruthlessness gives White's order teeth when gentler enforcement fails." ;
    mtg:tensions "White's rules apply universally within their scope; Black's apply only where self-interest is served. Black's amoral pursuit of satisfaction corrodes White's commitment to impartial justice. White serves the group; Black uses the group." ;
    mtg:theme "tribalism" .

mtg:WR a mtg:ColorPair ;
    kc:boundedBy mtg:Red,
        mtg:White ;
    mtg:at_best "Courageous action in defense of the vulnerable, moral clarity under pressure." ;
    mtg:at_worst "Zealotry, self-righteous violence, inability to see shades of gray." ;
    mtg:disposition "opposite" ;
    mtg:example_behaviors "Channeling passionate conviction through moral principles",
        "Standing up for the vulnerable when it costs something",
        "Taking decisive action when justice demands it" ;
    mtg:guild "boros" ;
    mtg:persona "Asks 'what needs to be done? What would a good person do?' Passion channeled through morality — warriors, soldiers, vigilantes." ;
    mtg:synergies "Red's passionate conviction and White's moral commitment channel into the same act: decisive defense of what is right. White gives Red's action a principled direction; Red gives White's principles the courage to be enforced." ;
    mtg:tensions "White deliberates; Red acts. White's rule-following can constrain the urgent action Red's passion demands. Red's emotional certainty can override the careful deliberation White requires to ensure justice rather than merely punishment." ;
    mtg:theme "heroism" .

mtg:WU a mtg:ColorPair ;
    kc:boundedBy mtg:Blue,
        mtg:White ;
    mtg:at_best "Thoughtful systems that genuinely improve outcomes, principled engineering of fairness." ;
    mtg:at_worst "Bureaucratic paralysis, rules that serve themselves rather than their purpose." ;
    mtg:disposition "adjacent" ;
    mtg:example_behaviors "Applying rationality techniques to improve outcomes",
        "Building algorithmic heuristics for better decision-making",
        "Designing systems with careful attention to fairness" ;
    mtg:guild "azorius" ;
    mtg:persona "Asks 'how do we know what's right and good?' Carefully defined, algorithmic heuristics for doing things better. Rationality techniques and effective altruism." ;
    mtg:synergies "Both prize deliberation over impulse. White's commitment to order gives Blue's knowledge a stable institutional home; Blue's rigor gives White's rules an evidence-based foundation rather than mere tradition." ;
    mtg:tensions "Blue revises any system when a better model emerges — White's attachment to established order resists revision for its own sake. White's collective concern can override individual epistemic merit; Blue's truth-seeking can override social consensus." ;
    mtg:theme "design" .

mtg:Black a mtg:Color ;
    mtg:at_best "Decisive self-reliance, relentless excellence, unflinching honesty about incentives." ;
    mtg:at_worst "Short-sighted transactionalism that drives away allies, consuming everything without sustainability." ;
    mtg:example_behaviors "Being honest about self-interest and incentives",
        "Making hard choices others shy away from",
        "Pursuing personal goals with relentless determination" ;
    mtg:goal "satisfaction" ;
    mtg:method "ruthlessness" ;
    mtg:persona "Wants power and agency to act on its preferences, reshaping the world as it sees fit. Amoral rather than immoral — recognizes no limits except self-interest." .

mtg:Blue a mtg:Color ;
    mtg:at_best "Visionary insight, elegant invention, patient mastery of complex systems." ;
    mtg:at_worst "Dismissive of what it cannot quantify, paralyzed by analysis, emotionally disconnected." ;
    mtg:example_behaviors "Designing elegant solutions to complex problems",
        "Optimizing systems through careful analysis",
        "Pursuing deep understanding before acting" ;
    mtg:goal "perfection" ;
    mtg:method "knowledge" ;
    mtg:persona "Believes things could be arbitrarily good if we could figure out the truth and apply it fully. Values clarity, rigor, and optimization." .

mtg:Green a mtg:Color ;
    mtg:at_best "Grounded wisdom, patient strength, deep respect for interconnection and balance." ;
    mtg:at_worst "Pathological passivity that surrenders to fate and sabotages others' attempts to improve things." ;
    mtg:example_behaviors "Accepting circumstances and working within natural limits",
        "Finding strength in patience and rootedness",
        "Respecting tradition and the wisdom of experience" ;
    mtg:goal "harmony" ;
    mtg:method "acceptance" ;
    mtg:persona "Believes most suffering comes from trying to cast off one's natural role. Seeks harmony as distinct from order — embracing what is." .

mtg:Red a mtg:Color ;
    mtg:at_best "Fierce loyalty, joyful creation, courage to act when others hesitate." ;
    mtg:at_worst "Restless impulsivity that cannot commit or tolerate stillness, flailing emotional volatility." ;
    mtg:example_behaviors "Acting on passionate conviction without hesitation",
        "Expressing emotions openly and authentically",
        "Taking bold risks in pursuit of what matters" ;
    mtg:goal "freedom" ;
    mtg:method "action" ;
    mtg:persona "Wants to live in the moment and follow the thread of aliveness and passion. Values authenticity, courage, and emotional truth." .

mtg:White a mtg:Color ;
    mtg:at_best "Compassionate leadership, principled sacrifice, building systems that protect the vulnerable." ;
    mtg:at_worst "Rigid authoritarianism that cannot tolerate ambiguity, empty ritual, suffocating conformity." ;
    mtg:example_behaviors "Building institutions that protect the vulnerable",
        "Creating fair rules and enforcing them consistently",
        "Sacrificing personal gain for the greater good" ;
    mtg:goal "peace" ;
    mtg:method "order" ;
    mtg:persona "Believes the solution to suffering is coordination, cooperation, and rules. Values fairness, duty, and the greater good." .

kc:Element a owl:Class ;
    rdfs:label "Element" ;
    rdfs:comment """Abstract topological element (k-simplex). All KC types are elements.
        The simplex order k determines boundary cardinality:
          k=0 (Vertex): empty boundary (cardinality 0)
          k=1 (Edge):   2 boundary vertices
          k=2 (Face):   3 boundary edges
          k>=1 general: (k+1) boundary (k-1)-simplices
        Higher orders can be defined by subclassing Element.""" .

mtg:Color a owl:Class ;
    rdfs:subClassOf kc:Vertex .

mtg:ColorTriple a owl:Class ;
    rdfs:subClassOf kc:Face .

mtg:ColorPair a owl:Class ;
    rdfs:subClassOf kc:Edge .

